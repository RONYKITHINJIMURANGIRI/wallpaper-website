# ============================================
# WALLPAPER CMS - ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local to version control
#

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For local development: PostgreSQL instance
# For Vercel: Use Vercel Postgres or Supabase
# Format: postgresql://user:password@host:port/database
#
DATABASE_URL="postgresql://user:password@localhost:5432/wallpaper_cms"


# ============================================
# SECURITY - JWT CONFIGURATION
# ============================================
# Generate strong secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use different secret for production!
#
JWT_SECRET="change-this-to-a-random-secure-string-in-production"
JWT_EXPIRATION=86400


# ============================================
# EMAIL CONFIGURATION (PASSWORD RESET)
# ============================================
# Setup Gmail App Password:
# 1. Enable 2-Step Verification
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Use the 16-character password (not your Gmail password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password-not-regular-password
SMTP_FROM=noreply@example.com


# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp


# ============================================
# ADMIN CREDENTIALS (CHANGE AFTER FIRST LOGIN!)
# ============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123


# ============================================
# NEXTAUTH (for future use)
# ============================================
NEXTAUTH_SECRET="change-this-to-a-random-string"
NEXTAUTH_URL=http://localhost:3000


# ============================================
# VERCEL DEPLOYMENT CONFIGURATION
# ============================================
# When deploying to Vercel:
#
# 1. Set in Vercel Dashboard → Settings → Environment Variables:
#    - DATABASE_URL (use Vercel Postgres or Supabase)
#    - JWT_SECRET (use different value than local!)
#    - All SMTP_* variables
#    - NEXTAUTH_SECRET
#
# 2. Vercel Blob Storage:
#    - Automatically available through @vercel/blob
#    - No additional setup needed
#    - All images stored in Vercel Blob CDN
#
# 3. Always use production-specific values!

